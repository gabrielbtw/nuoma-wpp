    "worker:stop": "node scripts/local-worker.mjs stop",
    "worker:restart": "node scripts/local-worker.mjs restart",
    "worker:status": "node scripts/local-worker.mjs status",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf .turbo node_modules",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.26.0",
    "@types/node": "^24.3.0",
