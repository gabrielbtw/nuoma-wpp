{
  "name": "nuoma-wpp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently -c cyan,magenta,yellow -n web-app,wa-worker,scheduler \"npm run dev --workspace @nuoma/web-app\" \"npm run dev --workspace @nuoma/wa-worker\" \"npm run dev --workspace @nuoma/scheduler\"",
    "build": "npm run build --workspaces --if-present",
    "test": "node --import tsx --test --test-concurrency=1 tests/review.test.ts",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "start": "pm2-runtime start ecosystem.config.cjs --env production",
    "db:migrate": "npm run migrate --workspace @nuoma/core",
    "db:seed": "npm run seed --workspace @nuoma/core",
    "db:import:instagram": "npm run import:instagram --workspace @nuoma/core --"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "pm2": "^6.0.8",
    "typescript": "^5.9.2"
  }
}
