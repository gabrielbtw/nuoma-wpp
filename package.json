{
  "name": "nuoma-wpp-v2",
  "version": "0.1.0",
  "private": true,
  "description": "Nuoma WPP V2 — local-first omnichannel CRM (greenfield rebuild). See docs/architecture/V2_DECISION.md.",
  "packageManager": "npm@10.9.3",
  "type": "module",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:v21-foundations": "node tests/v21-foundations-smoke.mjs",
    "test:v24-api-auth": "tsx tests/v24-api-auth-smoke.ts",
    "test:v25-sender-runtime": "tsx tests/v25-sender-runtime-smoke.ts",
    "test:v25-media": "node tests/v25-media-smoke.mjs",
    "test:v25-metrics": "node tests/v25-operational-metrics-smoke.mjs",
    "test:v26-attachments": "node tests/v26-attachment-candidates-smoke.mjs",
    "test:v26-profile-photo": "node tests/v26-profile-photo-smoke.mjs",
    "test:v27-ig-unified": "npm run test --workspace @nuoma/api -- src/app.test.ts -t \"unifies WhatsApp and Instagram conversations\"",
    "test:v28-visual": "node tests/v28-visual-smoke.mjs",
    "test:v29-inbox": "node tests/v29-inbox-smoke.mjs",
    "test:v29-inbox-e2e": "node tests/v29-inbox-e2e-smoke.mjs",
    "test:v29-individual-campaign": "node tests/v29-individual-campaign-smoke.mjs",
    "test:v29-markdown-notes": "node tests/v29-markdown-notes-smoke.mjs",
    "test:v29-optimistic-send": "node tests/v29-optimistic-send-smoke.mjs",
    "test:v29-queue-indicator": "node tests/v29-queue-indicator-smoke.mjs",
    "test:v29-retry-inline": "node tests/v29-retry-inline-smoke.mjs",
    "test:v29-sidebar-tabs": "node tests/v29-sidebar-tabs-smoke.mjs",
    "test:v29-automation-trigger": "node tests/v29-automation-trigger-smoke.mjs",
    "test:v29-delivery-status": "node tests/v29-delivery-status-smoke.mjs",
    "test:v29-emoji-picker": "node tests/v29-emoji-picker-smoke.mjs",
    "test:v29-message-actions": "node tests/v29-message-actions-smoke.mjs",
    "test:v29-quick-replies": "node tests/v29-quick-replies-smoke.mjs",
    "test:v29-reminders": "node tests/v29-reminders-smoke.mjs",
    "test:v29-timeline-glass": "node tests/v29-timeline-glass-smoke.mjs",
    "test:v29-voice-recorder": "node tests/v29-voice-recorder-smoke.mjs",
    "test:v29-virtual-list": "node tests/v29-virtual-list-smoke.mjs",
    "test:v210-campaigns": "node tests/v210-campaigns-smoke.mjs",
    "test:v210-ab-variants": "node tests/v210-ab-variants-smoke.mjs",
    "test:v210-chatbot-ab-rules": "node tests/v210-chatbot-ab-rules-smoke.mjs",
    "test:v210-evergreen": "node tests/v210-evergreen-smoke.mjs",
    "test:v210-pause-resume": "node tests/v210-pause-resume-smoke.mjs",
    "test:v210-recipient-audit-ic2": "node tests/v210-recipient-audit-ic2-smoke.mjs",
    "test:v210-flow-builders": "node tests/v210-flow-builders-smoke.mjs",
    "test:v210-step-stats": "node tests/v210-step-stats-smoke.mjs",
    "test:v210-hardening": "npm run test --workspace @nuoma/api -- src/services/campaign-scheduler.test.ts -t \"enqueues the next campaign step\" && npm run test --workspace @nuoma/api -- src/app.test.ts -t \"persists V2.10 chatbot execution history\" && npm run test --workspace @nuoma/worker -- src/job-loop.test.ts -t \"records started and failed evidence\"",
    "test:v210-remarketing-batch-real": "npm run test --workspace @nuoma/api -- src/app.test.ts -t \"guards and dispatches V2.10 real remarketing batches\"",
    "test:v211-overlay-unit": "npm run test --workspace @nuoma/worker -- src/features/overlay/inject.test.ts src/sync/cdp.test.ts",
    "test:v211-overlay-fab": "tsx tests/v211-overlay-fab-smoke.ts",
    "test:v211-overlay-panel": "tsx tests/v211-overlay-panel-smoke.ts",
    "test:v211-overlay-phone": "tsx tests/v211-overlay-phone-detection-smoke.ts",
    "test:v211-overlay-api": "tsx tests/v211-overlay-api-binding-smoke.ts",
    "test:v211-overlay-suite": "npm run test:v211-overlay-unit && npm run test:v211-overlay-fab && npm run test:v211-overlay-panel && npm run test:v211-overlay-phone && npm run test:v211-overlay-api",
    "test:v211-real-media": "node tests/v211-real-media-smoke.mjs",
    "test:v211-real-inbound": "node tests/v211-real-inbound-smoke.mjs",
    "test:v211-message-send-receive": "node tests/v211-message-send-receive-smoke.mjs",
    "test:v211-real-round-complete": "node tests/v211-real-round-complete-smoke.mjs",
    "test:v212-streaming-unit": "npm run test --workspace @nuoma/api -- src/services/streaming-cdp.test.ts",
    "test:v212-streaming-cdp": "npm run test:v212-streaming-unit && tsx tests/v212-streaming-cdp-strong-smoke.ts",
    "test:v213-global-events": "npm run test --workspace @nuoma/api -- src/app.test.ts -t \"streams V2.13 global events by channel with cursor support\"",
    "test:v213-global-events-strong": "node tests/v213-global-events-inbox-strong-smoke.mjs",
    "test:v214-backup-restore": "tsx tests/v214-backup-restore-smoke.ts",
    "test:v215-cutover-preflight": "tsx tests/v215-cutover-preflight-smoke.ts",
    "test:v215-cutover-apply": "tsx tests/v215-cutover-apply-smoke.ts",
    "test:v213-v215-suite": "npm run test:v213-global-events && npm run test:v214-backup-restore && npm run test:v215-cutover-preflight && npm run test:v215-cutover-apply",
    "test:v2-screen-smoke": "node tests/v2-screen-smoke-matrix.mjs",
    "test:m37-evidence-center": "npm run test --workspace @nuoma/api -- src/app.test.ts -t \"lists M37 evidence center\"",
    "build:chrome-extension": "npm run build --workspace @nuoma/chrome-extension",
    "test:m38-chrome-extension": "npm run test --workspace @nuoma/chrome-extension && npm run test --workspace @nuoma/api -- src/app.test.ts -t \"serves the M38 Chrome extension\" && node tests/m38-chrome-extension-smoke.mjs",
    "test:m303-neferpeel-temporary-context": "node tests/m303-neferpeel-temporary-context-smoke.mjs",
    "test:m303-wpp-24-send-90-proof": "node tests/m303-wpp-24-send-90-proof.mjs",
    "test:sync-top5": "node tests/sync-top5-conversations-smoke.mjs",
    "worker:start": "node scripts/local-worker.mjs start",
    "worker:stop": "node scripts/local-worker.mjs stop",
    "worker:restart": "node scripts/local-worker.mjs restart",
    "worker:status": "node scripts/local-worker.mjs status",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf .turbo node_modules",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.26.0",
    "@types/node": "^24.3.0",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.26.0",
    "globals": "^16.1.0",
    "playwright": "^1.59.1",
    "prettier": "^3.4.2",
    "simple-git-hooks": "^2.11.1",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.32.0",
    "vitest": "^3.1.4"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run typecheck && npm run lint"
  }
}
