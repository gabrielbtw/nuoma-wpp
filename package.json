    "prettier": "^3.4.2",
    "simple-git-hooks": "^2.11.1",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.32.0",
    "vitest": "^3.1.4"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run typecheck && npm run lint"
  }
}
