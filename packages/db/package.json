{
  "name": "@nuoma/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "echo \"@nuoma/db: source-only package, no build step\"",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@nuoma/contracts": "*",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.4.1",
    "drizzle-orm": "^0.36.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.29.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2"
  }
}
