# Nuoma WPP V2 — env scaffold
# Copy to .env and fill.

# === Core ===
NODE_ENV=development
TZ=America/Sao_Paulo

# === API (apps/api) ===
API_HOST=127.0.0.1
API_PORT=3001
API_LOG_LEVEL=info
API_JWT_SECRET=change-me-in-production
API_JWT_TTL_SECONDS=604800
API_REFRESH_TTL_SECONDS=2592000
API_CAMPAIGN_SCHEDULER_ENABLED=false
API_CAMPAIGN_SCHEDULER_INTERVAL_MS=30000
API_CAMPAIGN_SCHEDULER_USER_ID=1
API_SEND_POLICY_MODE=test
API_SEND_ALLOWED_PHONES=5531982066263
API_AUTOMATION_ENGINE_ENABLED=false
API_AUTOMATION_ENGINE_INTERVAL_MS=5000
API_AUTOMATION_ENGINE_USER_ID=1
API_AUTOMATION_ENGINE_ALLOWED_PHONE=5531982066263

# === CRM file storage ===
# local: writes beside DATABASE_URL under crm-files/nuoma/files/crm/<phone-or-contact>/
# s3: PUTs to S3-compatible storage under nuoma/files/crm/<phone-or-contact>/
API_CRM_STORAGE_PROVIDER=local
API_CRM_STORAGE_NAMESPACE=/nuoma/files/crm
# API_CRM_STORAGE_LOCAL_ROOT=../../data/crm-files
# API_CRM_STORAGE_S3_BUCKET=nuoma-files
API_CRM_STORAGE_S3_REGION=us-east-2
# API_CRM_STORAGE_S3_ENDPOINT=
API_CRM_STORAGE_S3_FORCE_PATH_STYLE=false
# API_CRM_STORAGE_S3_ACCESS_KEY_ID=
# API_CRM_STORAGE_S3_SECRET_ACCESS_KEY=
# API_CRM_STORAGE_S3_SESSION_TOKEN=

# === Web (apps/web) ===
WEB_PORT=3002
VITE_API_URL=http://127.0.0.1:3001
# Same public key as API_WEB_PUSH_VAPID_PUBLIC_KEY when browser push is enabled.
# VITE_WEB_PUSH_VAPID_PUBLIC_KEY=

# === Worker (apps/worker) ===
WORKER_HEADLESS=false
WORKER_BROWSER_ENABLED=false
WORKER_BROWSER_ATTACH_EXISTING=true
WORKER_KEEP_BROWSER_OPEN=true
WORKER_SYNC_ENABLED=false
WORKER_SYNC_RECONCILE_MS=60000
WORKER_SYNC_MULTI_CHAT_ENABLED=false
WORKER_SYNC_MULTI_CHAT_LIMIT=5
WORKER_SYNC_MULTI_CHAT_DELAY_MS=1200
WORKER_SEND_REUSE_OPEN_CHAT_ENABLED=false
WA_SEND_POLICY_MODE=test
WA_SEND_ALLOWED_PHONES=5531982066263
WA_SEND_RATE_LIMIT_WINDOW_MS=60000
WA_SEND_RATE_LIMIT_MAX=12
WORKER_JOB_LOOP_ENABLED=true
WORKER_ID=worker-local-1
WORKER_POLL_MS=1000
WORKER_HEARTBEAT_SEC=20
WORKER_MAX_RSS_MB=1200
WORKER_TEMP_DIR=../../data/tmp
CHROMIUM_PROFILE_DIR=../../data/chromium-profile/whatsapp
CHROMIUM_CDP_HOST=127.0.0.1
CHROMIUM_CDP_BIND_HOST=127.0.0.1
CHROMIUM_CDP_PORT=9223
WA_WEB_URL=https://web.whatsapp.com/
WA_INBOX_TARGET_PHONE=
# Legacy single-phone canary. Keep equal to WA_SEND_ALLOWED_PHONES in test mode.
WA_SEND_ALLOWED_PHONE=5531982066263

# === Database ===
DATABASE_URL=../../data/nuoma-v2.db

# === S3 backup (optional in dev) ===
S3_BUCKET=nuoma-files
S3_PREFIX=nuoma-wpp-v2
AWS_REGION=us-east-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# === Web Push (VAPID) ===
# Generate once and keep stable for browser subscriptions.
# API_WEB_PUSH_VAPID_PUBLIC_KEY=
# API_WEB_PUSH_VAPID_PRIVATE_KEY=
API_WEB_PUSH_VAPID_SUBJECT=mailto:owner@example.com

# === Email recovery (SES) ===
# SES_FROM=no-reply@nuoma.app
# SES_REGION=us-east-2
