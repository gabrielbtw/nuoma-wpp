NODE_ENV=development
APP_PORT=3000
APP_HOST=127.0.0.1
APP_NAME=Nuoma WPP
DATABASE_PATH=./storage/database/nuoma.db
LOG_LEVEL=info
DEBUG_MODE=false
LOG_DIR=./storage/logs
UPLOADS_DIR=./storage/uploads
MEDIA_DIR=./storage/media
TEMP_DIR=./storage/temp
SCREENSHOTS_DIR=./storage/screenshots
CHROMIUM_PROFILE_DIR=./storage/chromium-profile/whatsapp
CHROMIUM_CHANNEL=chrome
CHROMIUM_CDP_HOST=127.0.0.1
CHROMIUM_CDP_PORT=9222
CHROMIUM_HEADLESS=false
PLAYWRIGHT_SLOW_MO=0
WEB_APP_URL=
WEB_APP_OPEN_ON_STARTUP=true
WA_URL=https://web.whatsapp.com
IG_USE_SHARED_BROWSER=true
IG_OPEN_ON_STARTUP=true
IG_ENABLE_INBOX_SYNC=true
WA_SYNC_INTERVAL_SEC=180
IG_SYNC_INTERVAL_SEC=30
WA_SYNC_CHATS_LIMIT=6
WA_SYNC_MESSAGES_LIMIT=18
WORKER_HEARTBEAT_SEC=20
WORKER_MAX_RSS_MB=700
SCHEDULER_INTERVAL_SEC=20
WATCHDOG_STALE_SECONDS=90
ENABLE_PM2_WATCHDOG=false
ENABLE_CAMPAIGNS=true
ENABLE_AUTOMATIONS=true
ENABLE_POST_PROCEDURE=true
ENABLE_UPLOADS=true
MAX_UPLOAD_MB=200
DATA_LAKE_DIR=./storage/data-lake
AI_PROVIDER=auto
WHISPER_BIN=whisper-cli
WHISPER_MODEL_PATH=./storage/models/whisper/ggml-base-q5_1.bin
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_VISION_MODEL=gemma3:4b
DEFAULT_TIMEZONE=America/Sao_Paulo
DEFAULT_ATTENDANT=Operador Local
SAVE_HTML_ON_CRITICAL_ERROR=true
WORKER_FAILURE_THRESHOLD=3
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_VISION_MODEL=gpt-4.1-mini
